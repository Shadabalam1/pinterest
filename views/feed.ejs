<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head><link rel="stylesheet" href="/stylesheets/feed.css">
<body>
     <nav>
      <div class="logo">
        <h5>Pinterest</h5>
		  
      </div>
      <ul class="navLink">
        <li><a href="/feed">Feed</a></li>
        <li><a href="/profile">Profile</a></li>
        <li><a href="/logout">Logout</a></li>
      </ul>
	  <div class="lines">
		  <div class="l1"></div>
		  <div class="l2"></div>
		  <div class="l3"></div>
	  </div>
    </nav>
   
  
  
      
<div class="container">
  <% if (posts && posts.length > 0) { %>
    <% posts.forEach(post => { %>
      <div class="box">
        <a href="/uploads/<%= post.image %>">
         <img src="/images/uploads/<%= post.image %>" alt="Post image"> 
        </a>
        <div class="caption"><%= post.postText %></div>
        <div class="author">
          <strong><%= post.user ? post.user.username : "Unknown User" %></strong>
          <small>(<%= post.createdAt.toDateString() %>)</small>
        </div>
      </div>
    <% }) %>
  <% } else { %>
    <p>No posts yet.</p>
  <% } %>
</div>

 


	
	
	<script src="https://code.jquery.com/jquery-3.3.1.js"></script>
	  <script src="/javascripts/feed.js"></script>
</body>
				  

</html>